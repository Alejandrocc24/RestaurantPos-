# Base de datos (Supabase pooler requiere ?pgbouncer=true en la URL del pooler)
DEV_DATABASE_URL="postgresql://user:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Tras crear una BD nueva de tenant, aplicar stored procedures:
# npm run db:sp          → solo desarrollo
# npm run db:sp:all      → desarrollo + pruebas + producción

# JWT
JWT_SECRET="your-secret-key-here-change-in-production"
JWT_EXPIRES_IN="24h"

# Server
PORT=3000
NODE_ENV="development"

# Admin Database (para gestionar tenants)
ADMIN_DATABASE_URL="postgresql://user:password@localhost:5432/restaurante_admin"

# Render/Vercel
API_URL="http://localhost:3000"
