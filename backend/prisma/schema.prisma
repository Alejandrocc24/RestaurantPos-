generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id           String       @id @default(cuid())
  email        String       @unique
  nombre       String
  password     String
  activo       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  refreshToken String?
  gastos       Gasto[]
  ordenes      Orden[]
  roles        UsuarioRol[]
  ventas       Venta[]

  @@index([email])
  @@index([activo])
}

model UsuarioRol {
  id        String   @id @default(cuid())
  usuarioId String
  rolId     String
  createdAt DateTime @default(now())
  rol       Rol      @relation(fields: [rolId], references: [id], onDelete: Cascade)
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, rolId])
  @@index([usuarioId])
  @@index([rolId])
}

model Rol {
  id          String       @id @default(cuid())
  nombre      String       @unique
  descripcion String?
  permisos    String[]     @default([])
  activo      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  usuarios    UsuarioRol[]

  @@index([activo])
}

model Categoria {
  id            String         @id @default(cuid())
  nombre        String         @unique
  descripcion   String?
  activo        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  productos     Producto[]
  subcategorias Subcategoria[]

  @@index([activo])
}

model Subcategoria {
  id          String    @id @default(cuid())
  nombre      String
  descripcion String?
  activo      Boolean   @default(true)
  categoriaId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  categoria   Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  @@unique([nombre, categoriaId])
  @@index([categoriaId])
  @@index([activo])
}

model CategoriaGasto {
  id          String   @id @default(cuid())
  nombre      String   @unique
  descripcion String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  gastos      Gasto[]

  @@index([activo])
}

model Producto {
  id                  String              @id @default(cuid())
  nombre              String
  descripcion         String?
  precio              Float
  categoriaId         String
  subcategoria        String?
  activo              Boolean             @default(true)
  imagen              String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  comentarios         String?             @default("[]")
  configuracionGrupos String?             @default("[]")
  especial            Boolean             @default(false)
  gruposModificadores String?             @default("[]")
  opcionesModificador OpcionModificador[]
  ordenProductos      OrdenProducto[]
  categoria           Categoria           @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  modificadores       GrupoModificador[]  @relation("GrupoModificadorToProducto")

  @@index([categoriaId])
  @@index([activo])
  @@index([nombre])
}

model GrupoModificador {
  id            String              @id @default(cuid())
  nombre        String
  descripcion   String?
  requerido     Boolean             @default(false)
  activo        Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  cobrar_precio Boolean             @default(false)
  opciones      OpcionModificador[]
  productos     Producto[]          @relation("GrupoModificadorToProducto")

  @@index([activo])
}

model OpcionModificador {
  id              String           @id @default(cuid())
  nombre          String
  precioAdicional Float            @default(0)
  grupoId         String
  activo          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  productoId      String?
  categoria       String?
  grupo           GrupoModificador @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  producto        Producto?        @relation(fields: [productoId], references: [id])

  @@index([grupoId])
  @@index([productoId])
}

model Mesa {
  id        String     @id @default(cuid())
  numero    Int        @unique
  capacidad Int
  estado    EstadoMesa @default(DISPONIBLE)
  activo    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  posicion  String?
  ubicacion String?
  ordenes   Orden[]
  ventas    Venta[]

  @@index([estado])
  @@index([activo])
}

model Orden {
  id            String          @id @default(cuid())
  mesaId        String?
  usuarioId     String
  estado        EstadoOrden     @default(PENDIENTE)
  total         Float           @default(0)
  descuento     Float           @default(0)
  propina       Float           @default(0)
  createdAt     DateTime        @default(now())
  compledatAt   DateTime?
  updatedAt     DateTime        @updatedAt
  notas         String?
  visibleCocina Boolean         @default(true)
  comentarios   Comentario[]
  mesa          Mesa?           @relation(fields: [mesaId], references: [id])
  usuario       Usuario         @relation(fields: [usuarioId], references: [id])
  productos     OrdenProducto[]
  pagos         Pago[]

  @@index([mesaId])
  @@index([usuarioId])
  @@index([estado])
  @@index([createdAt])
}

model OrdenProducto {
  id             String   @id @default(cuid())
  ordenId        String
  productoId     String
  cantidad       Int
  precioUnitario Float
  subtotal       Float
  estado         String   @default("pendiente")
  notas          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  comentario     String?
  modificadores  String?
  orden          Orden    @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  producto       Producto @relation(fields: [productoId], references: [id])

  @@index([ordenId])
  @@index([productoId])
}

model Pago {
  id         String     @id @default(cuid())
  ordenId    String
  monto      Float
  metodoPago MetodoPago
  referencia String?
  estado     EstadoPago @default(COMPLETADO)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  orden      Orden      @relation(fields: [ordenId], references: [id], onDelete: Cascade)

  @@index([ordenId])
}

model Venta {
  id                String   @id @default(cuid())
  mesaId            String?
  usuarioId         String
  ordenId           String?
  total             Float
  estado            String   @default("completada")
  metodoPago        String
  fecha             DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  cantidadProductos Int      @default(0)
  productosJson     String?
  mesa              Mesa?    @relation(fields: [mesaId], references: [id])
  usuario           Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([mesaId])
  @@index([usuarioId])
  @@index([fecha])
  @@index([estado])
}

model Comentario {
  id             String         @id @default(cuid())
  ordenId        String
  contenido      String
  tipoComentario TipoComentario @default(GENERAL)
  severidad      Severidad      @default(NORMAL)
  activo         Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  orden          Orden          @relation(fields: [ordenId], references: [id], onDelete: Cascade)

  @@index([ordenId])
  @@index([tipoComentario])
  @@index([severidad])
  @@index([activo])
}

model ComentarioPreestablecido {
  id        String   @id @default(cuid())
  texto     String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([activo])
}

model Gasto {
  id                     String         @id @default(cuid())
  descripcion            String
  monto                  Float
  categoriaId            String
  usuarioId              String
  fecha                  DateTime       @default(now())
  recibo                 String?
  observaciones          String?
  salio_de_caja          Boolean        @default(true)
  activo                 Boolean        @default(true)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  proveedorId            String?
  proveedorPersonalizado String?
  categoria              CategoriaGasto @relation(fields: [categoriaId], references: [id])
  proveedor              Proveedor?     @relation(fields: [proveedorId], references: [id])
  usuario                Usuario        @relation(fields: [usuarioId], references: [id])

  @@index([categoriaId])
  @@index([usuarioId])
  @@index([proveedorId])
  @@index([fecha])
  @@index([activo])
}

model Caja {
  id                  String    @id @default(cuid())
  monto_inicial       Float     @default(0)
  monto_final         Float?
  estado              String    @default("abierta")
  usuario_apertura_id String?
  usuario_cierre_id   String?
  fecha_apertura      DateTime  @default(now())
  fecha_cierre        DateTime?
  total_gastos        Float     @default(0)
  activo              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([estado])
  @@index([fecha_apertura])
}

model Proveedor {
  id        String   @id @default(cuid())
  nombre    String   @unique
  contacto  String?
  correo    String?
  telefono  String?
  direccion String?
  ciudad    String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  compras   Compra[]
  gastos    Gasto[]

  @@index([activo])
}

model Compra {
  id              String       @id @default(cuid())
  proveedorId     String
  numeroDocumento String?
  monto           Float
  estado          EstadoCompra @default(COMPLETADA)
  observaciones   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  proveedor       Proveedor    @relation(fields: [proveedorId], references: [id])

  @@index([proveedorId])
}

model Configuracion {
  id          String   @id @default(cuid())
  clave       String   @unique
  valor       String
  tipo        String   @default("string")
  descripcion String?
  updatedAt   DateTime @updatedAt

  @@index([clave])
}

enum EstadoMesa {
  DISPONIBLE
  OCUPADA
  RESERVADA
  FUERA_DE_SERVICIO
}

enum EstadoOrden {
  PENDIENTE
  EN_CURSO
  COMPLETADA
  CANCELADA
  PAGADA
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
  CHEQUE
  OTRO
}

enum EstadoPago {
  PENDIENTE
  COMPLETADO
  CANCELADO
  REEMBOLSADO
}

enum TipoComentario {
  GENERAL
  PROBLEMA
  COMENTARIO_CLIENTE
  NOTA_INTERNA
  ADVERTENCIA
}

enum Severidad {
  BAJA
  NORMAL
  ALTA
  CRITICA
}

enum EstadoCompra {
  PENDIENTE
  COMPLETADA
  CANCELADA
}
