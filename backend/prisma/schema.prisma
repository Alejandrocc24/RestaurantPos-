// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USUARIOS Y AUTENTICACIÓN
// ============================================

model Usuario {
  id        String   @id @default(cuid())
  email     String   @unique
  nombre    String
  password  String
  activo    Boolean  @default(true)
  refreshToken String?
  
  // Relaciones
  roles     UsuarioRol[]
  gastos    Gasto[]
  ordenes   Orden[]
  ventas    Venta[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([activo])
}

model UsuarioRol {
  id        String   @id @default(cuid())
  usuarioId String
  rolId     String
  
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  rol       Rol      @relation(fields: [rolId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@unique([usuarioId, rolId])
  @@index([usuarioId])
  @@index([rolId])
}

model Rol {
  id          String   @id @default(cuid())
  nombre      String   @unique
  descripcion String?
  permisos    String[] @default([])  // Array de strings con nombres de permisos
  activo      Boolean  @default(true)
  
  // Relaciones
  usuarios    UsuarioRol[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([activo])
}

// ============================================
// CATÁLOGOS
// ============================================

model Categoria {
  id          String   @id @default(cuid())
  nombre      String   @unique
  descripcion String?
  activo      Boolean  @default(true)
  
  // Relaciones
  productos       Producto[]
  subcategorias   Subcategoria[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([activo])
}

model Subcategoria {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  activo      Boolean  @default(true)
  categoriaId String
  
  // Relaciones
  categoria   Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([nombre, categoriaId])
  @@index([categoriaId])
  @@index([activo])
}

model CategoriaGasto {
  id          String   @id @default(cuid())
  nombre      String   @unique
  descripcion String?
  activo      Boolean  @default(true)
  
  gastos      Gasto[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([activo])
}

model Producto {
  id            String   @id @default(cuid())
  nombre        String
  descripcion   String?
  precio        Float
  categoriaId   String
  subcategoria  String?
  activo        Boolean  @default(true)
  imagen        String?
  comentarios   String?  @default("[]")  // Array de comentarios preestablecidos como JSON
  especial      Boolean  @default(false)  // Indica si es un producto especial con modificadores
  gruposModificadores  String?  @default("[]")  // IDs de grupos modificadores como JSON array
  configuracionGrupos  String?  @default("[]")  // Configuración de cada grupo {grupoId, minSelecciones, maxSelecciones} como JSON array
  
  // Relaciones
  categoria     Categoria @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  ordenProductos OrdenProducto[]
  modificadores GrupoModificador[]
  opcionesModificador OpcionModificador[]  // Relación inversa
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([categoriaId])
  @@index([activo])
  @@index([nombre])
}

model GrupoModificador {
  id            String   @id @default(cuid())
  nombre        String
  descripcion   String?
  requerido     Boolean  @default(false)
  cobrar_precio Boolean  @default(false)
  activo        Boolean  @default(true)
  
  productos     Producto[]
  opciones      OpcionModificador[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([activo])
}

model OpcionModificador {
  id              String   @id @default(cuid())
  nombre          String
  precioAdicional Float    @default(0)
  grupoId         String
  productoId      String?  // Relación opcional con el producto
  activo          Boolean  @default(true)
  
  grupo           GrupoModificador @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  producto        Producto? @relation(fields: [productoId], references: [id], onDelete: SetNull)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([grupoId])
  @@index([productoId])
}

// ============================================
// MESAS Y ESPACIOS
// ============================================

model Mesa {
  id        String   @id @default(cuid())
  numero    Int      @unique
  capacidad Int
  estado    EstadoMesa @default(DISPONIBLE)
  activo    Boolean  @default(true)
  posicion  String?
  ubicacion String?
  
  ordenes   Orden[]
  ventas    Venta[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estado])
  @@index([activo])
}

enum EstadoMesa {
  DISPONIBLE
  OCUPADA
  RESERVADA
  FUERA_DE_SERVICIO
}

// ============================================
// ÓRDENES Y VENTAS
// ============================================

model Orden {
  id            String   @id @default(cuid())
  mesaId        String?
  usuarioId     String
  estado        EstadoOrden @default(PENDIENTE)
  total         Float    @default(0)
  descuento     Float    @default(0)
  propina       Float    @default(0)
  notas         String?
  visibleCocina Boolean  @default(true)
  
  // Relaciones
  mesa          Mesa?    @relation(fields: [mesaId], references: [id], onDelete: SetNull)
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  productos     OrdenProducto[]
  pagos         Pago[]
  comentarios   Comentario[]
  
  createdAt     DateTime @default(now())
  compledatAt   DateTime?
  updatedAt     DateTime @updatedAt

  @@index([mesaId])
  @@index([usuarioId])
  @@index([estado])
  @@index([createdAt])
}

enum EstadoOrden {
  PENDIENTE
  EN_CURSO
  COMPLETADA
  CANCELADA
  PAGADA
}

model OrdenProducto {
  id           String   @id @default(cuid())
  ordenId      String
  productoId   String
  cantidad     Int
  precioUnitario Float
  subtotal     Float
  estado       String   @default("pendiente")
  notas        String?
  comentario   String?  // Comentarios del producto (preestablecidos + personalizado combinados)
  modificadores String? // JSON array de modificadores seleccionados [{grupoId, grupoNombre, modificadores: [{nombre, precio}]}]
  
  orden        Orden    @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  producto     Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([ordenId])
  @@index([productoId])
}

model Pago {
  id            String   @id @default(cuid())
  ordenId       String
  monto         Float
  metodoPago    MetodoPago
  referencia    String?
  estado        EstadoPago @default(COMPLETADO)
  
  orden         Orden    @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([ordenId])
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
  CHEQUE
  OTRO
}

enum EstadoPago {
  PENDIENTE
  COMPLETADO
  CANCELADO
  REEMBOLSADO
}

// ============================================
// VENTAS (Transacciones completadas)
// ============================================

model Venta {
  id                 String   @id @default(cuid())
  mesaId             String?
  usuarioId          String
  ordenId            String?
  total              Float
  estado             String   @default("completada")
  metodoPago         String   // EFECTIVO, TARJETA, etc
  cantidadProductos  Int      @default(0)
  productosJson      String?  // Snapshot JSON de los productos cobrados
  fecha              DateTime @default(now())
  
  // Relaciones
  mesa          Mesa?    @relation(fields: [mesaId], references: [id], onDelete: SetNull)
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([mesaId])
  @@index([usuarioId])
  @@index([fecha])
  @@index([estado])
}

// ============================================
// COMENTARIOS
// ============================================

model Comentario {
  id            String   @id @default(cuid())
  ordenId       String
  contenido     String
  tipoComentario TipoComentario @default(GENERAL)
  severidad     Severidad @default(NORMAL)
  activo        Boolean  @default(true)
  
  orden         Orden    @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([ordenId])
  @@index([tipoComentario])
  @@index([severidad])
  @@index([activo])
}

model ComentarioPreestablecido {
  id            String   @id @default(cuid())
  texto         String
  activo        Boolean  @default(true)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([activo])
}

enum TipoComentario {
  GENERAL
  PROBLEMA
  COMENTARIO_CLIENTE
  NOTA_INTERNA
  ADVERTENCIA
}

enum Severidad {
  BAJA
  NORMAL
  ALTA
  CRITICA
}

// ============================================
// GASTOS E INVENTARIO
// ============================================

model Gasto {
  id                   String   @id @default(cuid())
  descripcion          String
  monto                Float
  categoriaId          String
  usuarioId            String
  proveedorId          String?
  proveedorPersonalizado String?
  fecha                DateTime @default(now())
  recibo               String?
  observaciones        String?
  salio_de_caja        Boolean  @default(true)
  activo               Boolean  @default(true)
  
  categoria            CategoriaGasto @relation(fields: [categoriaId], references: [id], onDelete: Restrict)
  usuario              Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Restrict)
  proveedor            Proveedor? @relation(fields: [proveedorId], references: [id], onDelete: SetNull)
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([categoriaId])
  @@index([usuarioId])
  @@index([proveedorId])
  @@index([fecha])
  @@index([activo])
}

// Modelo para cajas (apertura / cierre de caja)
model Caja {
  id                  String   @id @default(cuid())
  monto_inicial       Float    @default(0)
  monto_final         Float?
  estado              String   @default("abierta")
  usuario_apertura_id String?
  usuario_cierre_id   String?
  fecha_apertura      DateTime @default(now())
  fecha_cierre        DateTime?
  total_gastos        Float    @default(0)
  activo              Boolean  @default(true)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([estado])
  @@index([fecha_apertura])
}

model Proveedor {
  id            String   @id @default(cuid())
  nombre        String   @unique
  contacto      String?
  correo        String?
  telefono      String?
  direccion     String?
  ciudad        String?
  activo        Boolean  @default(true)
  
  compras       Compra[]
  gastos        Gasto[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([activo])
}

model Compra {
  id            String   @id @default(cuid())
  proveedorId   String
  numeroDocumento String?
  monto         Float
  estado        EstadoCompra @default(COMPLETADA)
  observaciones String?
  
  proveedor     Proveedor @relation(fields: [proveedorId], references: [id], onDelete: Restrict)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([proveedorId])
}

enum EstadoCompra {
  PENDIENTE
  COMPLETADA
  CANCELADA
}

// ============================================
// CONFIGURACIÓN Y ADMIN
// ============================================

model Configuracion {
  id            String   @id @default(cuid())
  clave         String   @unique
  valor         String
  tipo          String   @default("string")
  descripcion   String?
  
  updatedAt     DateTime @updatedAt

  @@index([clave])
}
